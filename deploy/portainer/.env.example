# =============================================================================
# CommonCreed posting stack — environment template
# =============================================================================
#
# Copy this file to `.env` in the same directory and replace EVERY placeholder
# value before deploying the stack.
#
#   cp .env.example .env
#   chmod 600 .env
#
# Placeholders below use obviously-fake values like `changeme-...` and
# `your-nas.local`. If you ever see a placeholder value in your running
# stack, you forgot to fill it in.
#
# NEVER commit your real .env to git. The repo's .gitignore should already
# exclude it; double-check before pushing.
# =============================================================================


# -----------------------------------------------------------------------------
# Postgres credentials (used by both the postgres service and Postiz)
# -----------------------------------------------------------------------------
POSTGRES_USER=postiz
POSTGRES_PASSWORD=changeme-long-random-postgres-password
POSTGRES_DB=postiz


# -----------------------------------------------------------------------------
# Postiz datastore URLs
# These reference the service names on the internal Docker network — do NOT
# change `postgres` / `redis` to a hostname unless you also rename the
# services in docker-compose.yml.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postiz:changeme-long-random-postgres-password@postgres:5432/postiz
REDIS_URL=redis://redis:6379


# -----------------------------------------------------------------------------
# Postiz core settings
# -----------------------------------------------------------------------------
# The hostname Postiz is reachable at from the LAN. If you use the Synology
# reverse proxy with a custom hostname, this is that hostname. If you go
# straight to port 5000, use http://your-nas.local:5000.
POSTIZ_MAIN_URL=http://your-nas.local:5000
POSTIZ_FRONTEND_URL=http://your-nas.local:5000

# JWT signing secret — generate a long random string. Suggested:
#   openssl rand -hex 48
POSTIZ_JWT_SECRET=changeme-generate-a-long-random-jwt-secret-at-least-64-chars

# Storage backend for uploaded media. "local" writes into the postiz_uploads
# named volume. Leave as "local" unless you have a specific reason to use S3.
POSTIZ_STORAGE_PROVIDER=local

# Lock down public registration once you've created your admin account.
# Set to "false" the first time you bring up the stack so you can register,
# then flip to "true" and redeploy.
POSTIZ_DISABLE_REGISTRATION=true


# =============================================================================
# Unit 2 — CommonCreed sidecar (placeholders only; not consumed in Unit 1)
# =============================================================================
# These vars are declared here so the .env file is complete from day one and
# Unit 2's sidecar service can be enabled without re-editing the file. The
# sidecar service is commented out in docker-compose.yml until Unit 2 lands.
# -----------------------------------------------------------------------------

# Postiz API key — generate from the Postiz UI under Settings → API Keys
# AFTER first login. Leave blank for the initial bootstrap.
POSTIZ_API_KEY=changeme-paste-postiz-api-key-from-ui

# Anthropic API key — used by the sidecar for topic scoring + caption gen.
ANTHROPIC_API_KEY=changeme-your-anthropic-api-key-here

# ElevenLabs API key — used by the existing pipeline subprocess.
ELEVENLABS_API_KEY=changeme-elevenlabs-api-key

# VEED / fal.ai API keys — used by the existing avatar pipeline.
VEED_API_KEY=changeme-veed-api-key
FAL_API_KEY=changeme-fal-api-key

# Pexels API key — used by the b-roll fetcher.
PEXELS_API_KEY=changeme-pexels-api-key

# Telegram bot — create via @BotFather, then DM the bot once to discover
# your numeric chat ID (the sidecar will help with this on first run).
TELEGRAM_BOT_TOKEN=changeme-123456789:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
TELEGRAM_CHAT_ID=changeme-numeric-chat-id

# Gmail OAuth — the sidecar reads this path inside its container. Place your
# downloaded `credentials.json` from Google Cloud Console at the matching
# host path mounted into the sidecar (see Unit 2 README).
GMAIL_OAUTH_PATH=/secrets/gmail_oauth.json

# Sidecar dashboard admin password (single-user LAN auth).
SIDECAR_ADMIN_PASSWORD=changeme-long-random-admin-password

# Pipeline schedule overrides (defaults shown). Local time on the NAS.
PIPELINE_TRIGGER_TIME=05:00
PIPELINE_SLOT_MORNING=09:00
PIPELINE_SLOT_EVENING=19:00
PIPELINE_AUTO_APPROVE_OFFSET_MIN=30

# Asset retention in days before old generated videos are pruned.
PIPELINE_RETENTION_DAYS=14
