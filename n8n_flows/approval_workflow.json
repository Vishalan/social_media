{
  "meta": {
    "instanceId": "a1b2c3d4e5f6g7h8"
  },
  "nodes": [
    {
      "id": "1",
      "name": "Webhook Content Submission",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 100],
      "parameters": {
        "path": "content-submission",
        "httpMethod": "POST",
        "options": {}
      }
    },
    {
      "id": "2",
      "name": "Notify Slack for Approval",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 1,
      "position": [250, 250],
      "parameters": {
        "operation": "sendMessage",
        "channelId": "{{$env.SLACK_CHANNEL_ID}}",
        "text": "📋 **New Content Awaiting Approval**\n\n**Topic:** {{$json.trending_topic}}\n**Platform:** {{$json.platform}}\n**Caption:** {{$json.caption}}\n**Script:** {{$json.script}}\n\nPlease review and approve or reject.",
        "attachments": [
          {
            "image_url": "={{$json.preview_url}}"
          }
        ]
      }
    },
    {
      "id": "3",
      "name": "Setup Approval Webhook",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [250, 400],
      "parameters": {
        "options": {}
      },
      "fields": {
        "newFields": [
          {
            "name": "approval_webhook_url",
            "type": "string",
            "value": "={{$baseUrl}}/webhook/content-approval-{{$json.content_id}}"
          },
          {
            "name": "approval_id",
            "type": "string",
            "value": "={{$json.content_id}}"
          }
        ]
      }
    },
    {
      "id": "4",
      "name": "Wait for Approval Response",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [250, 550],
      "parameters": {
        "waitType": "webhook",
        "webhookPath": "/approval/{{$json.approval_id}}",
        "options": {
          "timeoutType": "days",
          "timeout": 1
        }
      }
    },
    {
      "id": "5",
      "name": "Check Approval Status",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [250, 700],
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$json.approval_status}}",
              "operation": "equals",
              "value2": "approved"
            }
          ]
        }
      }
    },
    {
      "id": "6",
      "name": "Post to All Platforms",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [50, 850],
      "parameters": {
        "method": "POST",
        "url": "https://social-media-api.internal/v1/publish",
        "authentication": "generic",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "content_id",
              "value": "={{$json.content_id}}"
            },
            {
              "name": "platforms",
              "value": "[\"youtube\",\"tiktok\",\"instagram\",\"twitter\",\"linkedin\"]"
            },
            {
              "name": "scheduled_time",
              "value": "={{$json.scheduled_time}}"
            }
          ]
        }
      }
    },
    {
      "id": "7",
      "name": "Send Approval Confirmation",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 1,
      "position": [50, 1000],
      "parameters": {
        "operation": "sendMessage",
        "channelId": "{{$env.SLACK_CHANNEL_ID}}",
        "text": "✅ **Content Published Successfully**\n\n**Content ID:** {{$json.content_id}}\n**Topic:** {{$json.trending_topic}}\n**Published to:** YouTube, TikTok, Instagram, Twitter, LinkedIn\n**Time:** {{$json.scheduled_time}}"
      }
    },
    {
      "id": "8",
      "name": "Log Approved Content",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 2,
      "position": [50, 1150],
      "parameters": {
        "operation": "append",
        "sheetId": "{{$env.GOOGLE_SHEETS_ID}}",
        "range": "A1:E1",
        "columns": "timestamp,content_id,topic,status,approved_by"
      }
    },
    {
      "id": "9",
      "name": "Send Rejection Notice",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 1,
      "position": [450, 850],
      "parameters": {
        "operation": "sendMessage",
        "channelId": "{{$env.SLACK_CHANNEL_ID}}",
        "text": "❌ **Content Rejected**\n\n**Content ID:** {{$json.content_id}}\n**Topic:** {{$json.trending_topic}}\n**Rejection Reason:** {{$json.rejection_reason}}\n\nPlease revise and resubmit."
      }
    },
    {
      "id": "10",
      "name": "Create Revision Task",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [450, 1000],
      "parameters": {
        "method": "POST",
        "url": "https://project-management-api.internal/v1/tasks",
        "authentication": "generic",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "title",
              "value": "Revise content: {{$json.trending_topic}}"
            },
            {
              "name": "description",
              "value": "{{$json.rejection_reason}}"
            },
            {
              "name": "content_id",
              "value": "={{$json.content_id}}"
            },
            {
              "name": "priority",
              "value": "high"
            }
          ]
        }
      }
    },
    {
      "id": "11",
      "name": "Log Rejected Content",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 2,
      "position": [450, 1150],
      "parameters": {
        "operation": "append",
        "sheetId": "{{$env.GOOGLE_SHEETS_ID}}",
        "range": "A1:F1",
        "columns": "timestamp,content_id,topic,status,rejection_reason,revised"
      }
    },
    {
      "id": "12",
      "name": "Send Timeout Notification",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 1,
      "position": [700, 850],
      "parameters": {
        "operation": "sendMessage",
        "channelId": "{{$env.SLACK_CHANNEL_ID}}",
        "text": "⏰ **Approval Timeout**\n\n**Content ID:** {{$json.content_id}}\n**Topic:** {{$json.trending_topic}}\n\nNo approval received within 24 hours. Please review."
      }
    }
  ],
