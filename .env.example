# ─── AI APIs ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# ─── Content Creation APIs ───────────────────────────────────
# Voice provider — "elevenlabs" (cloud API) or "chatterbox" (local GPU, free).
# Chatterbox needs a reference audio clip (10-30s WAV of the target voice).
VOICE_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id
# Path to the reference WAV as the chatterbox container sees it.
# /opt/commoncreed/assets is mounted read-only at /app/refs in the container,
# so a file at /opt/commoncreed/assets/voice_ref.wav becomes /app/refs/voice_ref.wav.
# CHATTERBOX_REFERENCE_AUDIO=/app/refs/voice_ref.wav
# Sidecar URL (only override if chatterbox lives off the compose network).
# CHATTERBOX_ENDPOINT=http://commoncreed_chatterbox:7777
# CHATTERBOX_DEVICE=cuda   # set to "cpu" for CI or no-GPU dev
AYRSHARE_API_KEY=your-ayrshare-api-key

# ─── YouTube Data API ────────────────────────────────────────
YOUTUBE_API_KEY=your-youtube-api-key

# ─── GPU Cloud ───────────────────────────────────────────────
RUNPOD_API_KEY=your-runpod-api-key
VASTAI_API_KEY=your-vastai-api-key
# RunPod pod tuning (CommonCreed pipeline)
RUNPOD_GPU_TYPE_ID=NVIDIA GeForce RTX 4090
# RUNPOD_TEMPLATE_ID=your-template-id          # pre-built ComfyUI template (faster startup)
RUNPOD_NETWORK_VOLUME_ID=your-network-volume-id
# RUNPOD_COMFYUI_PORT=8188                     # default port

# ─── Avatar Provider ─────────────────────────────────────────
# Set AVATAR_PROVIDER to:
#   "veed"   — VEED Fabric 1.0 via fal.ai (~$0.08/s at 480p, native 9:16). Default.
#   "kling"  — Kling AI v2 Pro via fal.ai (~$0.115/s, native 9:16).
#   "heygen" — HeyGen Avatar IV (~$775+/month, 16:9 crop needed).
AVATAR_PROVIDER=veed

# fal.ai API key (used by VEED Fabric and Kling providers)
FAL_API_KEY=your-fal-api-key

# VEED Fabric 1.0 — portrait image URL + optional resolution (480p | 720p)
VEED_AVATAR_IMAGE_URL=https://raw.githubusercontent.com/YOUR_USERNAME/social_media/main/assets/logos/owner-portrait.jpg
VEED_RESOLUTION=480p

# Kling AI Avatar v2 Pro via fal.ai (fallback provider)
KLING_AVATAR_IMAGE_URL=https://raw.githubusercontent.com/YOUR_USERNAME/social_media/main/assets/logos/owner-portrait.jpg

# HeyGen Avatar IV (requires Pro plan for priority queue — standard queue = 24-36h)
HEYGEN_API_KEY=your-heygen-api-key
# Obtain by running: python scripts/avatar_gen/setup_heygen_avatar.py
HEYGEN_AVATAR_ID=your-avatar-id

# ─── Social Media Tokens (for direct API posting) ────────────
TIKTOK_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
FACEBOOK_PAGE_TOKEN=
TWITTER_BEARER_TOKEN=
LINKEDIN_ACCESS_TOKEN=

# ─── B-Roll Image Sources (all optional — degrades gracefully without keys) ───
PEXELS_API_KEY=                   # Pexels API key for high-quality licensed images
BING_SEARCH_API_KEY=              # Bing Image Search API key

# ─── CommonCreed Pipeline ────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_OWNER_USER_ID=your-telegram-user-id
# Path to owner reference video — HeyGen/Kling setup only — not used at runtime by the pipeline
REFERENCE_VIDEO_PATH=/path/to/your/reference-video.mp4
# Set COMFYUI_URL to bypass RunPod and use an existing ComfyUI instance (local dev)
# Leave unset to have the pipeline auto-start/stop a RunPod pod via RUNPOD_API_KEY
# COMFYUI_URL=http://localhost:8188
# COMFYUI_API_KEY=optional_only_if_comfyui_is_behind_auth

# ─── Posting Backend ─────────────────────────────────────────
# Posting layer (Postiz on Synology/Portainer, replaces Ayrshare)
POSTING_BACKEND=postiz  # postiz | ayrshare
POSTIZ_BASE_URL=http://your-synology.local:5000
POSTIZ_API_KEY=your_postiz_api_key_here
