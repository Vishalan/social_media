# Secrets — never commit
.env
*.pem
*.key

# Python
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
.venv/
venv/

# Generated output
output/
outputs/

# Media files (large, gitignored except assets/logos/)
*.mp3
*.mp4
*.wav
*.avi
*.mov
assets/input_media/
assets/spike/

# macOS
.DS_Store
**/.DS_Store

# Claude Code — only local session/state dirs are ignored.
# Project-scoped skills (.claude/skills/) ARE committed; they're repo tooling.
.claude/projects/
.claude/cache/
.claude/sessions/
.claude/todos/
.claude/ide/
.claude/statsig/
.claude/settings.local.json
.claude/shell-snapshots/

# Node
node_modules/

# Jupyter
.ipynb_checkpoints/
logs/*.log
logs/launchd_*.log
