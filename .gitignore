# Secrets — never commit
.env
*.pem
*.key

# Python
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
.venv/
venv/

# Generated output
output/
outputs/

# Media files (large, gitignored except assets/logos/ and assets/sfx/)
*.mp3
*.mp4
*.wav
*.avi
*.mov
assets/input_media/
assets/spike/

# Whitelist curated SFX bundles — these ARE committed despite *.wav rule above.
!assets/sfx/*.wav
# Vesper channel SFX pack (Unit 3 scaffolding; owner sources the actual .wav
# files pre-launch per the Vesper launch runbook).
!assets/vesper/sfx/*.wav

# macOS
.DS_Store
**/.DS_Store

# Claude Code — only local session/state dirs are ignored.
# Project-scoped skills (.claude/skills/) ARE committed; they're repo tooling.
.claude/projects/
.claude/cache/
.claude/sessions/
.claude/todos/
.claude/ide/
.claude/statsig/
.claude/settings.local.json
.claude/shell-snapshots/
.claude/scheduled_tasks.lock
.claude/*.lock

# Node
node_modules/

# Jupyter
.ipynb_checkpoints/
logs/*.log
logs/launchd_*.log

# Local secrets (OAuth client credentials, one-shot tokens, etc.)
.secrets/

# Git worktrees (used by parallel agent-team execution runs; content lives in branches, not main tree)
.worktrees/
