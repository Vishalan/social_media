{
  "_meta": {
    "vesper_note": "Flux schnell single-file bundle (Comfy-Org/flux1-schnell-fp8.safetensors). Substitution tokens: {{prompt}}, {{width}}, {{height}}, {{num_inference_steps}}, {{guidance_scale}}, {{seed}}. For schnell use steps=4, cfg=1.0. For flux1-dev (gated on HF) use steps=28, cfg=3.5 and swap ckpt_name.",
    "substitution_tokens": [
      "{{prompt}}",
      "{{width}}", "{{height}}",
      "{{num_inference_steps}}", "{{guidance_scale}}",
      "{{seed}}"
    ]
  },
  "10": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "flux1-schnell-fp8.safetensors"
    },
    "_meta": {"title": "Flux checkpoint (bundled)"}
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{prompt}}",
      "clip": ["10", 1]
    },
    "_meta": {"title": "Positive Prompt"}
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "",
      "clip": ["10", 1]
    },
    "_meta": {"title": "Empty Negative (Flux schnell ignores)"}
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "{{width}}",
      "height": "{{height}}",
      "batch_size": 1
    },
    "_meta": {"title": "Latent (9:16 Vesper)"}
  },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["10", 0],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["5", 0],
      "seed": "{{seed}}",
      "steps": "{{num_inference_steps}}",
      "cfg": "{{guidance_scale}}",
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0
    },
    "_meta": {"title": "KSampler"}
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["3", 0],
      "vae": ["10", 2]
    },
    "_meta": {"title": "VAE Decode"}
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "vesper_flux",
      "images": ["8", 0]
    },
    "_meta": {"title": "Save PNG"}
  }
}
